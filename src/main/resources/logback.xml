<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- JSON格式控制台输出，集成logstash-logback-encoder -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <!-- 自定义时间戳字段名 -->
            <timestampPattern>yyyy-MM-dd'T'HH:mm:ss.SSSZZ</timestampPattern>
            <!-- 包含MDC字段：taskID、api、code -->
            <includeMdcKeyName>taskID</includeMdcKeyName>
            <includeMdcKeyName>api</includeMdcKeyName>
            <includeMdcKeyName>code</includeMdcKeyName>
            <!-- 自定义字段名映射 -->
            <fieldNames>
                <timestamp>timestamp</timestamp>
                <version>[ignore]</version>
                <levelValue>[ignore]</levelValue>
            </fieldNames>
        </encoder>
    </appender>

    <!-- 按天滚动的文件输出，JSON格式 -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>logs/aid-sdk.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <!-- 按天滚动，保留30天 -->
            <fileNamePattern>logs/aid-sdk-%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>30</maxHistory>
        </rollingPolicy>
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <timestampPattern>yyyy-MM-dd'T'HH:mm:ss.SSSZZ</timestampPattern>
            <includeMdcKeyName>taskID</includeMdcKeyName>
            <includeMdcKeyName>api</includeMdcKeyName>
            <includeMdcKeyName>code</includeMdcKeyName>
            <fieldNames>
                <timestamp>timestamp</timestamp>
                <version>[ignore]</version>
                <levelValue>[ignore]</levelValue>
            </fieldNames>
        </encoder>
    </appender>

    <!-- 默认日志级别：DEBUG -->
    <root level="DEBUG">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
    </root>

    <!-- SDK内部日志 -->
    <logger name="com.aid.sdk" level="DEBUG" additivity="false">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
    </logger>
</configuration>
